---
import Example from "./Example.astro";
import "./Story.css";
import { route } from "virtual:astro-stories/config";

const { id } = Astro.props;
const uid = `story-${id.replace(/[^a-z0-9_-]/gi, "-")}-${crypto.randomUUID()}`;
const base = import.meta.env.BASE_URL;
const src = `${base}${route.replace(/^\//, "")}?id=${id}`;

export interface Props {
  title?: string;
  code?: string;
}
---

<Example>
  <div class="docs-story-canvas">
    <div class="astro-stories-canvas">
      <div class="astro-stories-canvas-frame">
        <iframe
          id={uid}
          class="astro-stories-iframe"
          loading="lazy"
          src={src}
          title={`Story ${id}`}
        />
      </div>
    </div>

    <div class="docs-story-canvas-actions">
      <a
        class="docs-story-action-button"
        href={src}
        rel="noreferrer"
        target="_blank"
        title="Open example in new tab"
      >
        <svg-icon class="block" name="external" />
      </a>
    </div>
  </div>

  <script is:inline define:vars={{ uid, id }}>
    const iframe = document.getElementById(uid);
    if (!(iframe instanceof HTMLIFrameElement)) {
      throw new Error(`Story iframe "${uid}" is missing`);
    }

    const handleMessage = (event) => {
      if (event.source !== iframe.contentWindow) {
        return;
      }
      if (event.data?.id !== id) {
        return;
      }

      iframe.style.height = `${event.data.height}px`;
    };

    window.addEventListener("message", handleMessage);
  </script>
</Example>
