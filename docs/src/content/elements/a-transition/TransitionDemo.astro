---
import "@sv/elements/transition";
---

<div class="flex gap-2 mb-4">
  <button type="button" id="shuffle" class="btn">Shuffle</button>
  <button type="button" id="add" class="btn">Add item</button>
  <button type="button" id="remove" class="btn">Remove item</button>
</div>

<a-transition id="demo" animate-enter animate-exit style="transition-duration: 350ms;">
  <div data-key="1" class="transition-item">Item 1</div>
  <div data-key="2" class="transition-item">Item 2</div>
  <div data-key="3" class="transition-item">Item 3</div>
  <div data-key="4" class="transition-item">Item 4</div>
</a-transition>

<style>
  #demo {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
    gap: 0.5rem;
  }
  :global(.transition-item) {
    padding: 0.75rem 1rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.375rem;
    background: var(--sl-color-gray-6);
    text-align: center;
  }
</style>

<script>
  const demo = document.getElementById("demo")!;
  let counter = 5;

  document.getElementById("shuffle")!.addEventListener("click", () => {
    const children = [...demo.children] as HTMLElement[];
    children.sort(() => Math.random() - 0.5);
    demo.append(...children);
  });

  document.getElementById("add")!.addEventListener("click", () => {
    const el = document.createElement("div");
    el.dataset.key = String(counter++);
    el.className = "transition-item";
    el.textContent = `Item ${counter - 1}`;
    demo.appendChild(el);
  });

  document.getElementById("remove")!.addEventListener("click", () => {
    const children = [...demo.children];
    if (children.length) children[Math.floor(Math.random() * children.length)]!.remove();
  });
</script>
